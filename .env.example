# ── App (read by Next.js / Prisma) ──────────────────────────────
# Local dev against a Postgres you run yourself:
DATABASE_URL="postgresql://savings:savings@localhost:5432/savings?schema=public"

# Generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET="replace-me-with-random-secret"

# Public site URL — used for SEO canonical/OG links, robots & sitemap.
# In prod set to your domain (falls back to AUTH_URL, then localhost).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── AI (Google Gemini) — server-side only, never exposed to the client ──
# Get a key at https://aistudio.google.com/apikey . AI features are disabled
# (buttons hidden / actions return a "not configured" error) when unset.
GEMINI_API_KEY=""
# Optional model overrides:
#  - GEMINI_MODEL: light tasks — parse/suggest/coach (default gemini-2.5-flash-lite)
#  - GEMINI_CHAT_MODEL: "ask your data" chat (function calling, needs a stronger
#    model; default gemini-2.5-flash). flash-lite is too weak for the chat.
# GEMINI_MODEL="gemini-2.5-flash-lite"
# GEMINI_CHAT_MODEL="gemini-2.5-flash"

# ── Docker Compose only ─────────────────────────────────────────
# Postgres container credentials (compose builds DATABASE_URL from these)
POSTGRES_USER=savings
POSTGRES_PASSWORD=savings
POSTGRES_DB=savings

# Run prisma db seed on container start (demo user + sample plan). Default false.
SEED_ON_START=false
