# ── App (read by Next.js / Prisma) ──────────────────────────────
# Local dev against a Postgres you run yourself:
DATABASE_URL="postgresql://savings:savings@localhost:5432/savings?schema=public"

# Generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET="replace-me-with-random-secret"

# ── Docker Compose only ─────────────────────────────────────────
# Postgres container credentials (compose builds DATABASE_URL from these)
POSTGRES_USER=savings
POSTGRES_PASSWORD=savings
POSTGRES_DB=savings

# Run prisma db seed on container start (demo user + sample plan). Default false.
SEED_ON_START=false
