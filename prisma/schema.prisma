// PostgreSQL (Docker / prod). CategoryType stored as String + validated in code so
// the schema stays portable back to SQLite for quick local dev if needed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  // Opt-in for AI features: user acknowledged that financial figures are sent
  // to Google's Gemini API. Required before any coach-summary generation.
  aiOptIn      Boolean  @default(false)
  plans        Plan[]
  createdAt    DateTime @default(now())
}

model Plan {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  description  String        @default("")
  currency     String        @default("THB")
  targetAmount Float
  startDate    DateTime
  targetDate   DateTime
  archived     Boolean       @default(false)
  // Milestone percentages already celebrated (e.g. [25, 50]) so confetti fires once.
  celebratedMilestones Int[]   @default([])
  categories   Category[]
  transactions Transaction[]
  recurringRules RecurringRule[]
  insightSummaries InsightSummary[]
  createdAt    DateTime      @default(now())

  @@index([userId])
}

// Cached AI coach summary per plan per month. content is the Gemini-generated
// Thai prose; figures fed to it are computed deterministically in our code.
model InsightSummary {
  id          String   @id @default(cuid())
  planId      String
  plan        Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  month       String   // "YYYY-MM"
  content     String
  generatedAt DateTime @default(now())

  @@unique([planId, month])
  @@index([planId])
}

model Category {
  id             String        @id @default(cuid())
  planId         String
  plan           Plan          @relation(fields: [planId], references: [id], onDelete: Cascade)
  name           String
  type           String // INCOME | FIXED | VARIABLE | SAVING
  plannedMonthly Float         @default(0)
  sortOrder      Int           @default(0)
  transactions   Transaction[]
  recurringRules RecurringRule[]

  @@unique([planId, name])
  @@index([planId])
}

model Transaction {
  id           String   @id @default(cuid())
  planId       String
  plan         Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id])
  date         DateTime
  amount       Float
  description  String
  note         String   @default("")
  // For SAVING-category rows only: true = withdrawal (เบิกออก) that subtracts from
  // the goal's pot instead of a deposit. amount stays positive; the sign is applied
  // in calc. Always false for INCOME/FIXED/VARIABLE.
  isWithdrawal Boolean  @default(false)
  // Links transactions mirrored across plans (same income/expense entered once,
  // shared into other goals). All copies in a group share this id; deleting one
  // deletes the group. Null = not synced. Only for INCOME/FIXED/VARIABLE.
  syncGroupId  String?
  // Set when this row was materialized from a RecurringRule. Used to dedupe
  // lazy generation (one row per rule per month) and to label generated entries.
  sourceRuleId String?
  sourceRule   RecurringRule? @relation(fields: [sourceRuleId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([planId])
  @@index([categoryId])
  @@index([sourceRuleId])
  @@index([syncGroupId])
}

model RecurringRule {
  id           String        @id @default(cuid())
  planId       String
  plan         Plan          @relation(fields: [planId], references: [id], onDelete: Cascade)
  categoryId   String
  category     Category      @relation(fields: [categoryId], references: [id])
  amount       Float
  description  String
  dayOfMonth   Int           // 1..31, clamped to the month's last day at materialization
  startDate    DateTime
  endDate      DateTime?     // inclusive; no entries generated after this month
  active       Boolean       @default(true)
  transactions Transaction[]
  skips        RecurringSkip[]
  createdAt    DateTime      @default(now())

  @@index([planId])
  @@index([categoryId])
}

// Records a (rule, month) occurrence the user deleted by hand, so lazy
// materialization won't recreate it on the next load. ym is "YYYY-MM".
model RecurringSkip {
  id        String        @id @default(cuid())
  ruleId    String
  rule      RecurringRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  ym        String
  createdAt DateTime      @default(now())

  @@unique([ruleId, ym])
  @@index([ruleId])
}
